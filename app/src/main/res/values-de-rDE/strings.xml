    <string name="visibility_description_excellent">Außergewöhnliche Klarheit; auch weit entfernte Details sind gut zu erkennen</string>
    <string name="visibility_description_very_good">Sehr klare Bedingungen</string>
    <string name="visibility_description_good"></string>
    <string name="visibility_description_moderate">Diesig; entfernte Objekte sind leicht verschleiert.</string>
